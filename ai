<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Market Predict - Alpha Core AI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #08090a; overflow: hidden; }
        .cursor { display: inline-block; width: 8px; height: 15px; background: #4ade80; margin-left: 4px; animation: blink 0.8s infinite; }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
        .chat-bubble { border-radius: 20px 20px 20px 4px; }
        #chat-container { scroll-behavior: smooth; height: calc(100vh - 180px); overflow-y: auto; }

        /* --- ANIMASI SCANNING --- */
        #scan-screen {
            position: fixed;
            inset: 0;
            background-color: #08090a;
            z-index: 100;
            display: flex;
            flex-col;
            align-items: center;
            justify-content: center;
            font-family: 'Courier New', monospace;
            color: #4ade80;
            text-transform: uppercase;
            font-size: 10px;
            letter-spacing: 0.2em;
        }

        .scan-text { animation: pulse 1s infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

        /* Sembunyikan chat utama di awal */
        #main-chat { display: none; opacity: 0; transition: opacity 1s; }
    </style>
</head>
<body class="text-white antialiased flex flex-col min-h-screen">

    <div id="scan-screen">
        <div class="text-center p-6 space-y-2">
            <div>&lt; SYSTEM STATUS: OPTIMAL &gt;</div>
            <div class="text-lg font-black text-white scan-text">[ INITIALIZING ALPHA CORE ]</div>
            <div>[ DECRYPTING NETWORK ]</div>
            <div>[ LOADING RIALO V2.4 ]</div>
        </div>
    </div>

    <div id="main-chat">
        <nav class="border-b border-gray-800 bg-[#08090a] px-6 py-4 flex justify-between items-center sticky top-0 z-50">
            <div class="flex items-center gap-2">
                <div class="w-6 h-6 rounded-full bg-[#FDFDD0] flex items-center justify-center font-bold text-black text-xs">M</div>
                <span class="text-sm font-black uppercase tracking-widest text-white">Alpha Core <span class="text-green-500 text-[9px] ml-1 opacity-70">ONLINE</span></span>
            </div>
            <a href="menu.html" class="text-[9px] font-bold text-gray-500 uppercase tracking-widest hover:text-white transition">Back to Menu</a>
        </nav>

        <main class="flex-grow p-4 max-w-md mx-auto w-full space-y-6" id="chat-container">
            <div class="flex flex-col items-start" id="welcome-bubble" style="display: none;">
                <div class="bg-[#1e2023] border border-gray-800 p-4 chat-bubble text-sm leading-relaxed max-w-[90%] shadow-lg text-green-400 font-mono">
                    [SYSTEM INITIALIZED]<br>
                    Welcome, User. I am **Alpha Core**, the primary intelligence unit of the **Rialo Network**. 
                    I am ready to process your queries.
                    <br><br>
                    <span class="text-gray-500 text-[10px] font-bold uppercase tracking-wider">Try asking: "What is Rialo?"</span>
                </div>
            </div>
        </main>

        <div class="p-4 border-t border-gray-800 bg-[#08090a] sticky bottom-0">
            <div class="max-w-md mx-auto relative">
                <input type="text" id="user-input" placeholder="Enter command or question..." 
                    class="w-full bg-[#1e2023] border border-gray-700 rounded-full py-4 px-6 pr-14 text-sm focus:outline-none focus:border-green-500 transition shadow-inner placeholder:text-gray-600">
                <button onclick="handleSend()" class="absolute right-2 top-2 bg-white text-black p-2.5 rounded-full hover:bg-gray-200 transition active:scale-90 shadow-md">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" />
                    </svg>
                </button>
            </div>
            <p class="text-[8px] text-center text-gray-700 mt-2.5 uppercase tracking-widest">Powered by Rialo Layer 1 Technology</p>
        </div>
    </div>

    <script>
        // Logika Scanning
        window.addEventListener('load', () => {
            const scanScreen = document.getElementById('scan-screen');
            const mainChat = document.getElementById('main-chat');
            const welcomeBubble = document.getElementById('welcome-bubble');

            // Durasi scan 3 detik
            setTimeout(() => {
                scanScreen.style.opacity = '0';
                setTimeout(() => {
                    scanScreen.style.display = 'none';
                    mainChat.style.display = 'flex';
                    mainChat.style.flexDirection = 'column';
                    document.body.style.overflow = 'auto';
                    
                    // Transisi halus masuk
                    setTimeout(() => {
                        mainChat.style.opacity = '1';
                        // Munculkan welcome bubble
                        welcomeBubble.style.display = 'block';
                    ], 100);
                }, 1000); // Transisi fade-out
            }, 3000);
        });

        const chatContainer = document.getElementById('chat-container');
        const userInput = document.getElementById('user-input');

        // English Knowledge Base
        const responses = {
            "rialo": "RIALO is a high-performance Layer 1 Blockchain designed for maximum data transparency. It provides the essential infrastructure for decentralized applications and verified market analytics.",
            "what is rialo": "RIALO is the core foundation of our ecosystem. It is a decentralized network that allows real-time data processing with institutional-grade security, making it the perfect home for Market Predict.",
            "whats rialo": "RIALO is a next-generation blockchain protocol. It ensures that every prediction generated by the Alpha Engine is cross-referenced with on-chain data for 100% transparency.",
            "prediction": "The Alpha Prediction algorithm utilizes Rialo's high-speed data streams to identify market anomalies. Current success rate is calibrated at 89.4% based on historical Alpha patterns.",
            "safe": "Security is our priority. The Rialo network uses advanced cryptographic verification. We do not store user funds or private keys; we provide pure, decentralized intelligence.",
            "hello": "System online. Greetings, User. Alpha Core is ready to process your requests."
        };

        function handleSend() {
            const rawText = userInput.value.trim();
            const text = rawText.toLowerCase();
            if (text === "") return;

            addChatBubble(rawText, 'user');
            userInput.value = "";

            // AI "Thinking" Delay
            setTimeout(() => {
                let botResponse = "Error 404: Query not recognized in Alpha Core database. Please try asking about 'Rialo' or 'Market Safety'.";
                
                for (let key in responses) {
                    if (text.includes(key)) {
                        botResponse = responses[key];
                        break;
                    }
                }
                
                addChatBubble(botResponse, 'bot');
            }, 1000);
        }

        function addChatBubble(msg, sender) {
            const wrapper = document.createElement('div');
            wrapper.className = sender === 'user' ? 'flex flex-col items-end' : 'flex flex-col items-start';
            
            const bubble = document.createElement('div');
            bubble.className = sender === 'user' 
                ? 'bg-white text-black font-bold p-3 px-5 rounded-2xl rounded-tr-none text-sm max-w-[85%] shadow-md' 
                : 'bg-[#1e2023] border border-gray-800 p-4 chat-bubble text-sm leading-relaxed max-w-[90%] shadow-xl text-green-400 font-mono';
            
            wrapper.appendChild(bubble);
            chatContainer.appendChild(wrapper);

            if (sender === 'bot') {
                typeEffect(bubble, msg);
            } else {
                bubble.innerText = msg;
            }

            // Scroll to bottom
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }

        function typeEffect(element, text) {
            let i = 0;
            element.innerHTML = "";
            function type() {
                if (i < text.length) {
                    element.innerHTML += text.charAt(i);
                    i++;
                    setTimeout(type, 20);
                } else {
                    element.innerHTML += '<span class="cursor"></span>';
                    chatContainer.scrollTop = chatContainer.scrollHeight;
                }
            }
            type();
        }

        userInput.addEventListener("keypress", (e) => {
            if (e.key === "Enter") handleSend();
        });
    </script>
</body>
</html>
