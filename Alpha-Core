<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Market Predict - Alpha AI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #08090a; }
        .cursor { display: inline-block; width: 8px; height: 15px; background: #4ade80; margin-left: 4px; animation: blink 0.8s infinite; }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
        .chat-bubble { border-radius: 20px 20px 20px 4px; }
    </style>
</head>
<body class="text-white antialiased flex flex-col min-h-screen">

    <nav class="border-b border-gray-800 bg-[#08090a] px-6 py-4 flex justify-between items-center sticky top-0 z-50">
        <div class="flex items-center gap-2">
            <div class="w-6 h-6 rounded-full bg-[#FDFDD0] flex items-center justify-center font-bold text-black text-xs">M</div>
            <span class="text-sm font-black uppercase tracking-widest">Alpha Intelligence</span>
        </div>
        <a href="index.html" class="text-[10px] font-bold text-gray-500 uppercase tracking-tighter hover:text-white transition">Exit Terminal</a>
    </nav>

    <main class="flex-grow p-4 overflow-y-auto max-w-md mx-auto w-full space-y-6" id="chat-container">
        <div class="flex flex-col items-start">
            <div class="bg-[#1e2023] border border-gray-800 p-4 chat-bubble text-sm leading-relaxed max-w-[90%] shadow-lg">
                Greetings. I am **Alpha AI**, your core intelligence for the **Rialo Ecosystem**. 
                How can I assist your market analysis today?
                <br><br>
                <span class="text-gray-500 text-[10px] font-bold italic uppercase tracking-wider">Hint: Try asking "What is Rialo?"</span>
            </div>
        </div>
    </main>

    <div class="p-4 border-t border-gray-800 bg-[#08090a] sticky bottom-0">
        <div class="max-w-md mx-auto relative">
            <input type="text" id="user-input" placeholder="Type your query here..." 
                class="w-full bg-[#1e2023] border border-gray-700 rounded-full py-3.5 px-6 pr-12 text-sm focus:outline-none focus:border-green-500 transition shadow-inner placeholder:text-gray-600">
            <button onclick="handleSend()" class="absolute right-2 top-2 bg-white text-black p-2 rounded-full hover:bg-gray-200 transition active:scale-90">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" />
                </svg>
            </button>
        </div>
    </div>

    <script>
        const chatContainer = document.getElementById('chat-container');
        const userInput = document.getElementById('user-input');

        // English Knowledge Base
        const responses = {
            "rialo": "RIALO is a high-performance Layer 1 Blockchain ecosystem designed for data transparency and decentralized verification. It serves as the backbone for Market Predict, ensuring all analytical results are tamper-proof and verified on-chain.",
            "what is rialo": "RIALO is the ultimate infrastructure for the next generation of Web3 applications. It provides the neural network required for our Alpha Prediction engine to process real-time market data with maximum precision.",
            "whats rialo": "RIALO is the ultimate infrastructure for the next generation of Web3 applications. It provides the neural network required for our Alpha Prediction engine to process real-time market data with maximum precision.",
            "prediction": "Our system utilizes the Alpha Neural algorithm to scan market patterns. Currently, the win probability is sustained at 89.4% based on verified Rialo Network data streams.",
            "safety": "The system is fully decentralized. We never require your private keys. All market analysis is performed client-side using open data verified by the Rialo validator nodes.",
            "hello": "Hello. Alpha AI is online. System status: Optimal. How can I help you regarding Rialo today?"
        };

        function handleSend() {
            const rawText = userInput.value.trim();
            const text = rawText.toLowerCase();
            if (text === "") return;

            // User Bubble
            addChatBubble(rawText, 'user');
            userInput.value = "";

            // AI Thinking Simulation
            setTimeout(() => {
                let botResponse = "Access Denied: Information not found in Alpha Database. Please try asking: 'What is Rialo?' or 'How does prediction work?'";
                
                for (let key in responses) {
                    if (text.includes(key)) {
                        botResponse = responses[key];
                        break;
                    }
                }
                
                addChatBubble(botResponse, 'bot');
            }, 1000);
        }

        function addChatBubble(msg, sender) {
            const wrapper = document.createElement('div');
            wrapper.className = sender === 'user' ? 'flex flex-col items-end' : 'flex flex-col items-start';
            
            const bubble = document.createElement('div');
            bubble.className = sender === 'user' 
                ? 'bg-white text-black font-bold p-3 px-5 rounded-2xl rounded-tr-none text-sm max-w-[85%] shadow-md' 
                : 'bg-[#1e2023] border border-gray-800 p-4 chat-bubble text-sm leading-relaxed max-w-[90%] shadow-xl text-green-400 font-mono';
            
            wrapper.appendChild(bubble);
            chatContainer.appendChild(wrapper);

            if (sender === 'bot') {
                typeEffect(bubble, msg);
            } else {
                bubble.innerText = msg;
            }

            window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
        }

        function typeEffect(element, text) {
            let i = 0;
            element.innerHTML = "";
            function type() {
                if (i < text.length) {
                    element.innerHTML += text.charAt(i);
                    i++;
                    setTimeout(type, 20);
                } else {
                    element.innerHTML += '<span class="cursor"></span>';
                }
            }
            type();
        }

        userInput.addEventListener("keypress", (e) => {
            if (e.key === "Enter") handleSend();
        });
    </script>
</body>
</html>
